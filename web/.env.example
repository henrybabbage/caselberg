# Public (exposed to browser — safe for read-only project + dataset)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-01-01

# Private — only if dataset is private or you need elevated access
# SANITY_API_READ_TOKEN=

# Dev-only: absolute path to monorepo root for sv-agentation (open-in-editor). Only loaded when `npm run dev`.
# Example: PUBLIC_AGENTATION_WORKSPACE_ROOT=/Users/you/Programming/contiguous/caselberg
# PUBLIC_AGENTATION_WORKSPACE_ROOT=
